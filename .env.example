# ==========================================================================
# Solarpower Management - Environment Configuration
# --------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. Docker Compose reads the
# root `.env` automatically for variable interpolation. Nothing is hardcoded
# in the Dockerfiles, compose files, or the CI workflow.
#
# For CI (GitHub Actions), the frontend VITE_* values plus DOCKER_USERNAME /
# DOCKER_TOKEN must be stored as GitHub repository secrets (not in this file).
# ==========================================================================

# ==========================================
# Docker Hub / Registry
# ==========================================
# Docker Hub namespace used by compose.prod.yaml to pull the published images.
DOCKER_REGISTRY_USER=your_dockerhub_username

# ==========================================
# MongoDB
# ==========================================
# NOTE: backend_rev reads MONGODB_URI, solar-unit-api reads MONGODB_URL (both kept as-is).
# Dev default points to the bundled `mongo` service. For production, point these
# at your managed cluster (e.g. MongoDB Atlas).
MONGODB_URI=mongodb://mongo:27017/solarpower
MONGODB_URL=mongodb://mongo:27017/solarpower

# ==========================================
# Shared service configuration
# ==========================================
# Shared secret used for internal service-to-service authentication.
INTERNAL_API_KEY=your_internal_service_secret
# Public URL of the frontend (used for CORS + Stripe return URL in the backend).
FRONTEND_URL=http://localhost:5173

# ==========================================
# backend_rev (main API)
# ==========================================
# Clerk auth (read implicitly by @clerk/express)
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Stripe payments
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Cron schedule for the energy-sync scheduler (optional; app default: */5 * * * *)
SYNC_CRON_SCHEDULE=*/5 * * * *

# ==========================================
# solar-unit-api (data service)
# ==========================================
# Cron schedule for energy generation (optional; app default: 0 */2 * * *)
ENERGY_CRON_SCHEDULE=0 */2 * * *

# ==========================================
# Frontend (Vite) - baked at build time, also used at dev runtime
# ==========================================
VITE_BACKEND_URL=http://localhost:3000
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
VITE_WEATHER_KEY=your_weather_api_key
VITE_WEATHER_API=your_weather_api_base_url
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# ==========================================
# Host port mappings (optional overrides)
# ==========================================
FRONTEND_DEV_PORT=5173
FRONTEND_PORT=80
BACKEND_PORT=3000
UNIT_API_PORT=8000
MONGO_PORT=27017
